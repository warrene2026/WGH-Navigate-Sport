NEXT_PUBLIC_SUPABASE_URL=your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — from Supabase dashboard: Project Settings -> API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — from a Resend account (resend.com)
RESEND_API_KEY=your-resend-api-key
# Needs a verified sending domain in Resend; sandbox mode restricts
# sending to the Resend account owner's own address only.
RESEND_FROM_EMAIL="Navigate YS <reports@yourdomain.com>"
